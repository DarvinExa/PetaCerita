# Salin ke .env.local dan isi nilainya. Jangan commit .env.local.

# --- Database (server only) ---
# Koneksi pooled (PgBouncer, port 6543) untuk runtime aplikasi.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Koneksi langsung (port 5432) khusus untuk migrasi Prisma.
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase (aman untuk browser) ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<publishable-or-anon-key>"

# --- Supabase (server only) ---
# Service role key: JANGAN pernah diekspos ke browser.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
