// Skema Prisma untuk PetaCerita.
// Model domain (User, Trip, dst.) ditambahkan pada milestone M1+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: URL runtime disuntik lewat driver adapter di src/server/db.ts,
  // URL migrasi lewat datasource di prisma.config.ts.
}

// Peran anggota di dalam satu trip.
enum TripRole {
  OWNER
  MEMBER
}

// Cara seorang user bergabung ke trip.
enum JoinMethod {
  OWNER // pembuat trip
  INVITE_LINK // gabung lewat shareable link
}

// Kategori tempat dan item itinerary (PRD 5.2).
enum ItineraryCategory {
  ALAM
  ENTERTAIN
  KULINER
  PENGINAPAN
  TRANSPORT
}

// Kategori budget planner (PRD 5.4). Terpisah dari ItineraryCategory karena
// sudut pandangnya biaya, bukan jenis tempat.
enum BudgetCategory {
  TRANSPORT
  PENGINAPAN
  MAKAN
  TIKET
  LAINNYA
}

// Status penyelesaian utang dua arah: debitur submit sebagai PENDING, lalu
// kreditur mengonfirmasi menjadi CONFIRMED atau menolak kembali ke UNPAID.
enum SettlementStatus {
  UNPAID
  PENDING
  CONFIRMED
}

enum SettlementEventType {
  SUBMITTED
  CANCELLED
  CONFIRMED
  REJECTED
}

// User selaras dengan Supabase Auth: User.id = auth user UID.
// Row di-upsert dari sesi terverifikasi saat login (lihat src/server/auth.ts).
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedTrips  Trip[]       @relation("TripOwner")
  memberships TripMember[]

  @@map("users")
}

model Trip {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  city         String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  coverUrl     String?
  baseCurrency String   @default("IDR")
  ownerId      String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner          User            @relation("TripOwner", fields: [ownerId], references: [id])
  members        TripMember[]
  days           Day[]
  invites        TripInvite[]
  places         Place[]
  itineraryItems ItineraryItem[]
  expenses       Expense[]
  settlements    Settlement[]
  budgetPlans    BudgetPlan[]

  @@index([ownerId])
  @@map("trips")
}

// Shareable invite link untuk sebuah trip. Token disimpan sebagai hash SHA-256
// (kolom tokenHash) untuk lookup dan verifikasi. Token mentah juga disimpan
// (kolom token) agar Owner bisa menyalin ulang link dari panel, sesuai
// keputusan produk (link re-viewable, mirip Google Sheets/Canva).
// Satu trip punya paling banyak satu invite aktif; regenerate mengganti baris.
model TripInvite {
  id          String    @id @default(uuid()) @db.Uuid
  tripId      String    @unique @db.Uuid
  token       String    @unique
  tokenHash   String    @unique
  createdById String    @db.Uuid
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_invites")
}

model TripMember {
  id        String     @id @default(uuid()) @db.Uuid
  tripId    String     @db.Uuid
  userId    String     @db.Uuid
  role      TripRole   @default(MEMBER)
  joinedVia JoinMethod @default(INVITE_LINK)
  joinedAt  DateTime   @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  paidExpenses    Expense[]          @relation("ExpensePayer")
  itemShares      ExpenseItemShare[]
  settlementsFrom Settlement[]       @relation("SettlementFrom")
  settlementsTo   Settlement[]       @relation("SettlementTo")
  settlementEvents SettlementEvent[] @relation("SettlementEventActor")

  // Satu user hanya boleh sekali jadi anggota per trip.
  @@unique([tripId, userId])
  @@index([userId])
  @@map("trip_members")
}

model Day {
  id     String   @id @default(uuid()) @db.Uuid
  tripId String   @db.Uuid
  date   DateTime @db.Date
  order  Int

  trip  Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ItineraryItem[]

  // Satu tanggal unik per trip; order untuk urutan tampil.
  @@unique([tripId, date])
  @@index([tripId, order])
  @@map("days")
}

// Tempat kandidat dalam sebuah trip. Pada M3 diisi manual (nama, kategori,
// alamat, catatan). Kolom Google (googlePlaceId, rating, photoUrls, lat, lng)
// sengaja nullable agar M4 bisa mengisinya lewat Places API tanpa migrasi
// skema atau migrasi data. Biaya perkiraan ada di ItineraryItem, bukan di sini.
model Place {
  id            String            @id @default(uuid()) @db.Uuid
  tripId        String            @db.Uuid
  name          String
  category      ItineraryCategory
  address       String?
  note          String?
  googlePlaceId String?
  rating        Float?
  photoUrls     String[]
  lat           Float?
  lng           Float?
  googleMapsUrl String?
  createdById   String            @db.Uuid
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  trip  Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ItineraryItem[]

  @@index([tripId])
  @@map("places")
}

// Satu entri itinerary. dayId null berarti masih di Bucket Ide (belum
// dijadwalkan). Waktu disimpan sebagai string "HH:MM" agar bebas timezone,
// selaras dengan pendekatan date-only di src/lib/dates.ts. estimatedCost
// disimpan sebagai integer minor unit (rupiah utuh), bukan float, sesuai
// aturan keamanan uang. order menentukan urutan dalam Bucket atau dalam hari.
model ItineraryItem {
  id            String            @id @default(uuid()) @db.Uuid
  tripId        String            @db.Uuid
  dayId         String?           @db.Uuid
  placeId       String            @db.Uuid
  startTime     String?
  endTime       String?
  category      ItineraryCategory
  note          String?
  estimatedCost Int?
  order         Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day   Day?  @relation(fields: [dayId], references: [id], onDelete: SetNull)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([dayId, order])
  @@index([placeId])
  @@map("itinerary_items")
}

// Sebuah bill/tagihan (PRD 5.5). Payer adalah anggota yang membayar di depan;
// peserta lain berutang ke payer lewat share tiap item. Total bill TIDAK
// disimpan: diturunkan dari jumlah item agar tidak pernah drift dari detailnya.
//
// Multi-currency: amount tiap item disimpan dalam `currency` (integer minor
// unit). Untuk netting semua dikonversi ke base currency trip memakai
// `exchangeRateToBase` (1 unit currency = N unit base) yang dicatat saat bill
// dibuat, sesuai keputusan PRD (kurs manual, tersimpan per expense).
model Expense {
  id                 String          @id @default(uuid()) @db.Uuid
  tripId             String          @db.Uuid
  payerId            String          @db.Uuid
  title              String
  date               DateTime        @db.Date
  currency           String          @default("IDR")
  // Kurs ke base currency trip. Decimal (bukan float) agar konversi presisi.
  // Bernilai 1 jika currency == baseCurrency trip.
  exchangeRateToBase Decimal         @default(1) @db.Decimal(18, 8)
  budgetCategory     BudgetCategory?
  createdById        String          @db.Uuid
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  trip  Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payer TripMember    @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  items ExpenseItem[]

  @@index([tripId])
  @@index([payerId])
  @@map("expenses")
}

// Satu item dalam bill (mis. satu menu). `amount` integer minor unit dalam
// currency expense induk. `isShared` menandai biaya bersama (pajak, service,
// parkir) yang dibagi rata ke semua peserta bill, bukan per-item assignment.
model ExpenseItem {
  id        String   @id @default(uuid()) @db.Uuid
  expenseId String   @db.Uuid
  name      String
  amount    Int
  isShared  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  expense Expense            @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  shares  ExpenseItemShare[]

  @@index([expenseId])
  @@map("expense_items")
}

// Bagian seorang anggota atas sebuah item (PRD 8). `shareAmount` integer minor
// unit dalam currency expense; jumlah seluruh share satu item == amount item
// (dijaga di lapisan aplikasi lewat distribusi sisa/largest remainder). Default
// rata di antara peserta item, tapi bisa di-override manual.
model ExpenseItemShare {
  id            String @id @default(uuid()) @db.Uuid
  expenseItemId String @db.Uuid
  memberId      String @db.Uuid
  shareAmount   Int

  item   ExpenseItem @relation(fields: [expenseItemId], references: [id], onDelete: Cascade)
  member TripMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // Satu baris share per anggota per item.
  @@unique([expenseItemId, memberId])
  @@index([memberId])
  @@map("expense_item_shares")
}

// Transfer hasil netting antar anggota (PRD 8). Dihitung dari akumulasi semua
// bill di halaman Settle Up; baris menyimpan state konfirmasi dua arah.
// `amount` integer minor unit dalam base currency trip.
model Settlement {
  id           String           @id @default(uuid()) @db.Uuid
  tripId       String           @db.Uuid
  fromMemberId String           @db.Uuid
  toMemberId   String           @db.Uuid
  amount       Int
  status       SettlementStatus @default(UNPAID)
  submittedAt  DateTime?
  settledAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  trip Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  from TripMember @relation("SettlementFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  to   TripMember @relation("SettlementTo", fields: [toMemberId], references: [id], onDelete: Cascade)
  events SettlementEvent[]

  // Satu baris arah pembayaran per pasangan anggota per trip.
  @@unique([tripId, fromMemberId, toMemberId])
  @@index([tripId])
  @@map("settlements")
}

// Audit trail status transfer. Actor selalu anggota trip dan aksi divalidasi
// terhadap arah transfer: from mengirim atau membatalkan, to mengonfirmasi atau
// menolak.
model SettlementEvent {
  id            String              @id @default(uuid()) @db.Uuid
  settlementId  String              @db.Uuid
  actorMemberId String              @db.Uuid
  type          SettlementEventType
  createdAt     DateTime            @default(now())

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  actor      TripMember @relation("SettlementEventActor", fields: [actorMemberId], references: [id], onDelete: Cascade)

  @@index([settlementId, createdAt])
  @@index([actorMemberId])
  @@map("settlement_events")
}

// Estimasi budget per kategori (PRD 5.4). `amount` integer minor unit dalam
// base currency trip. Realisasi TIDAK disimpan: dihitung dari expense.
model BudgetPlan {
  id        String         @id @default(uuid()) @db.Uuid
  tripId    String         @db.Uuid
  category  BudgetCategory
  amount    Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Satu baris estimasi per kategori per trip.
  @@unique([tripId, category])
  @@index([tripId])
  @@map("budget_plans")
}
